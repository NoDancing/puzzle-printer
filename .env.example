# Option 1: NYT-S cookie (recommended — email/password login is blocked by Cloudflare)
# Get this from your browser: DevTools → Application → Cookies → nytimes.com → NYT-S
NYT_S=your_nyt_s_cookie_value

# Option 2: email/password (may not work due to Cloudflare bot protection)
# NYT_EMAIL=you@example.com
# NYT_PASSWORD=yourpassword

# IPP URI of your network printer, e.g. ipp://192.168.1.100/ipp/print
# Leave blank to use the system default printer (macOS only)
PRINTER=ipp://192.168.1.x/ipp/print
